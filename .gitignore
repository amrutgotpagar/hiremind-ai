node_modules/
**/node_modules/

# Environment variables (secrets)
.env
**/.env
.env.local
.env.*.local

# Uploaded files (user resumes — shouldn't be in git)
backend/uploads/*
!backend/uploads/.gitkeep

# Build output
frontend/dist/
frontend/build/

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/*
!.vscode/extensions.json